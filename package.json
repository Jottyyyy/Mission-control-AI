{
  "name": "mission-control-ai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently -k -n vite,electron -c blue,magenta \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "build:workspace-template": "mkdir -p MissionControl-AdamBuild && tar -czf MissionControl-AdamBuild/workspace-template.tgz -C workspace-template . && cp scripts/verify_bundle_fresh.sh MissionControl-AdamBuild/verify_bundle_fresh.sh && chmod +x MissionControl-AdamBuild/verify_bundle_fresh.sh",
    "electron:build": "npm run build && npm run build:workspace-template && electron-builder --mac"
  },
  "dependencies": {
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.jsp.missioncontrol",
    "productName": "Mission Control",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dir",
      "icon": "build/icon.png",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "extraResources": [
      {
        "from": "backend",
        "to": "app/backend",
        "filter": ["**/*.py", "!**/__pycache__/**", "!**/*.pyc"]
      }
    ]
  }
}

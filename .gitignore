node_modules/
dist/
dist-electron/
# MissionControl-AdamBuild/ is the hand-built deploy folder. We track the
# hand-written source files (install command, README, BUILD_INFO) but
# ignore the regenerated binaries (.zip, .tgz) and the script that's
# auto-copied from scripts/ at build time.
MissionControl-AdamBuild/MissionControl.app.zip
MissionControl-AdamBuild/workspace-template.tgz
MissionControl-AdamBuild/verify_bundle_fresh.sh
.DS_Store
.env

# Workspace template: never commit per-user artefacts that creep in if
# someone mirrors their real ~/.openclaw/workspace/ into this folder.
workspace-template/.backups/
workspace-template/memory/*.md
workspace-template/state/
workspace-template/.openclaw/

# Generated at build time by `npm run build:workspace-template`; shipped
# in MissionControl-AdamBuild/ which is already ignored above, but list it
# explicitly so it can't sneak into the repo from a different path.
workspace-template.tgz

# Local test fixtures — lead data is never committed (contains PII).
test-leads.csv
test-leads*.csv
test-zint-sample.csv
test-zint*.csv
